<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:controller="com.quizzybee.controller.LoginController"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="app-shell">
    <children>
        <ImageView fitWidth="1040.0" mouseTransparent="true" opacity="0.3" pickOnBounds="false"
                   preserveRatio="true" smooth="true" StackPane.alignment="CENTER_RIGHT"
                   styleClass="login-background-image" translateX="100.0">
            <image>
                <Image url="@assets/login-plane.jpg"/>
            </image>
        </ImageView>
        <HBox alignment="CENTER" spacing="28.0" StackPane.alignment="CENTER">
            <children>
                <VBox prefWidth="380.0" prefHeight="300.0" maxHeight="643.0" spacing="16.0" styleClass="sidebar-panel" style="-fx-background-radius: 30; -fx-border-radius: 30;">
                    <padding>
                        <Insets top="22.0" right="28.0" bottom="32.0" left="28.0"/>
                    </padding>
                    <children>
                        <ImageView fitWidth="320.0" pickOnBounds="true" preserveRatio="true" smooth="true">
                            <image>
                                <Image url="@assets/quizzybee-logo.png"/>
                            </image>
                        </ImageView>
                        <Label text="Enhance your problem-solving and technical skills through adaptive quizzes, progress tracking, and competitive leaderboards.."
                               wrapText="true" styleClass="hero-text"/>
                        <Label text="Learn. Practice. Improve. Repeat."
                               wrapText="true" styleClass="muted-label"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <ImageView fitWidth="300.0" pickOnBounds="true" preserveRatio="true" smooth="true">
                            <image>
                                <Image url="@assets/quizzybee-learning.png"/>
                            </image>
                        </ImageView>
                    </children>
                </VBox>
                <VBox prefWidth="420.0" spacing="16.0" styleClass="content-card login-card">
                    <padding>
                        <Insets top="40.0" right="36.0" bottom="36.0" left="36.0"/>
                    </padding>
                    <children>
                        <Label text="Sign In" styleClass="section-title"/>
                        <Label text="Continue as a learner or administrator." styleClass="muted-label"/>
                        <TextField fx:id="emailField" promptText="Email address"/>
                        <PasswordField fx:id="passwordField" promptText="Password"/>
                        <Button text="Login as User" onAction="#handleUserLogin" maxWidth="1.7976931348623157E308" styleClass="primary-button"/>
                        <Button text="Login as Admin" onAction="#handleAdminLogin" maxWidth="1.7976931348623157E308" styleClass="secondary-button"/>
                        <Button text="Create New Account" onAction="#handleGoToRegister" maxWidth="1.7976931348623157E308" styleClass="ghost-button"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
